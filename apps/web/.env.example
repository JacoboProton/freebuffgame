# ===========================================
# Duobi-Jac - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!

# ===========================================
# DATABASE (InsForge PostgreSQL)
# ===========================================
# Get these from your InsForge dashboard
# https://insforge.dev/dashboard/project/<project-id>
DATABASE_URL=postgresql://postgres:<PASSWORD>@<HOST>.database.insforge.app:5432/insforge?sslmode=require

# ===========================================
# INSFORGE CONFIGURATION
# ===========================================
# Your InsForge project URL
NEXT_PUBLIC_INSFORGE_URL=https://<project-id>.us-east.insforge.app

# Anonymous key for client-side (safe to expose)
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_key_here

# API key for server-side operations (KEEP SECRET!)
INSFORGE_API_KEY=your_api_key_here

# ===========================================
# API CONFIGURATION
# ===========================================
# URL for API requests (client-side)
NEXT_PUBLIC_API_URL=https://<project-id>.us-east.insforge.app/api/rest/V1

# ===========================================
# NEXTAUTH.JS AUTHENTICATION
# ===========================================
# Production URL of your site
NEXTAUTH_URL=https://<your-site>.insforge.site

# Generate with: openssl rand -base64 32
# IMPORTANT: Change this in production!
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production

# ===========================================
# ENVIRONMENT
# ===========================================
# Set to 'production' for production builds
NODE_ENV=development