DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/duobijac?schema=public\"
JWT_SECRET=\"your-super-secret-jwt-key-change-in-production\"
NODE_ENV=\"development\"
PORT=3001
CORS_ORIGIN=\"http://localhost:3000\"

# ===========================================
# GOOGLE OAUTH (Optional)
# ===========================================
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Your frontend URL for redirects
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ===========================================
# CLERK AUTHENTICATION (Required for Clerk/Google OAuth users)
# ===========================================
# Get this from Clerk Dashboard: https://dashboard.clerk.com
# API Keys -> Secret Key (sk_test_... or sk_live_...)
CLERK_SECRET_KEY=sk_test_RufBuu6h6MLlp5H96lXnmOCQJ36OmPR2QKrCE6hC9L

# ===========================================
# STRIPE PAYMENTS (Optional)
# ===========================================
# Get these from Stripe Dashboard: https://dashboard.stripe.com/apikeys
# Use test mode keys for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# To get Stripe keys:
# 1. Go to https://dashboard.stripe.com/apikeys
# 2. Copy the "Publishable key" (starts with pk_) and "Secret key" (starts with sk_)
# 3. For webhook secret, go to Developers > Webhooks and add an endpoint:
#    URL: http://localhost:3001/api/payments/webhook
#    Events: checkout.session.completed, payment_intent.succeeded

# ===========================================
# WEB PUSH NOTIFICATIONS (Optional)
# ===========================================
# Generate VAPID keys using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or use https://web-push-codelab.glitch.me/

# Public key (safe to expose to frontend)
VAPID_PUBLIC_KEY=your-vapid-public-key

# Private key (KEEP SECRET - never expose to frontend)
VAPID_PRIVATE_KEY=your-vapid-private-key

# Subject (mailto or https URL for VAPID)
VAPID_SUBJECT=mailto:notifications@yourdomain.com

# For the frontend, also set:
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key