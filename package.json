{
  "name": "duobijac",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build": "cd apps/web && npx prisma generate --schema=../api/prisma/schema.prisma && npx next build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed"
  },
  "devDependencies": {
    "@duobijac/shared": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport": "^1.0.17",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.5.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "web": "workspace:*"
  },
  "packageManager": "npm@10.2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "inngest": "^4.5.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "5.22.0"
  }
}
